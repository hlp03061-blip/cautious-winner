<!DOCTYPE html>
<html lang="zh-HK">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>波段策略綜合決策儀表板 (Supabase 直連版)</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen p-6">
    <div class="max-w-7xl mx-auto space-y-6">
        
        <header class="bg-gray-900 border border-gray-800 p-6 rounded-2xl shadow-xl space-y-4">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center border-b border-gray-800 pb-4 gap-4">
                <div>
                    <h1 class="text-2xl font-bold bg-gradient-to-r from-purple-400 via-pink-400 to-indigo-400 bg-clip-text text-transparent">
                        📊 港股波段策略綜合決策儀表板 (Supabase 直連)
                    </h1>
                    <p class="text-xs text-gray-400 mt-1">即時權重矩陣運算 • 視覺化板塊共振 • 智慧動態潛力排序</p>
                </div>
                <div class="bg-gray-950 px-4 py-2 rounded-xl border border-gray-800 text-right">
                    <span class="text-gray-500 text-xs font-bold block">數據日期</span>
                    <span id="latest-date" class="text-sm font-mono text-pink-400 font-bold">連線中...</span>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 pt-2">
                <div class="space-y-2">
                    <div class="flex justify-between text-xs font-bold text-gray-400">
                        <span>💰 大單資金流權重</span>
                        <span id="w-flow-val" class="text-indigo-400 font-mono">40%</span>
                    </div>
                    <input type="range" id="w-flow" min="0" max="100" value="40" class="w-full h-1.5 bg-gray-800 rounded-lg appearance-none cursor-pointer accent-indigo-500">
                </div>

                <div class="space-y-2">
                    <div class="flex justify-between text-xs font-bold text-gray-400">
                        <span>📈 技術面指標權重</span>
                        <span id="w-tech-val" class="text-purple-400 font-mono">30%</span>
                    </div>
                    <input type="range" id="w-tech" min="0" max="100" value="30" class="w-full h-1.5 bg-gray-800 rounded-lg appearance-none cursor-pointer accent-purple-500">
                </div>

                <div class="space-y-2">
                    <div class="flex justify-between text-xs font-bold text-gray-400">
                        <span>⚡ 量能爆發力權重</span>
                        <span id="w-vol-val" class="text-pink-400 font-mono">30%</span>
                    </div>
                    <input type="range" id="w-vol" min="0" max="100" value="30" class="w-full h-1.5 bg-gray-800 rounded-lg appearance-none cursor-pointer accent-pink-500">
                </div>

                <div class="space-y-2 bg-gray-950/50 p-2 rounded-xl border border-gray-800/60">
                    <div class="flex justify-between text-xs font-bold text-gray-400">
                        <span>🛑 最小成交量比 (Volspike)</span>
                        <span id="filter-vol-val" class="text-yellow-400 font-mono">1.0x</span>
                    </div>
                    <input type="range" id="filter-vol" min="5" max="40" value="10" step="5" class="w-full h-1.5 bg-gray-800 rounded-lg appearance-none cursor-pointer accent-yellow-500">
                </div>
            </div>
        </header>

        <section class="bg-gray-900 border border-gray-800 p-5 rounded-2xl shadow-xl">
            <h2 class="text-sm font-bold text-gray-400 mb-4 flex items-center gap-2">
                🎯 資金板塊共振牆 (Sector Resonance Clusters) <span class="text-xs font-normal text-gray-500">(方塊大小代表5日資金流入，顏色深淺代表綜合得分)</span>
            </h2>
            <div id="sector-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                <div class="col-span-full p-8 text-center text-gray-500">正在連線並歸類板塊數據...</div>
            </div>
        </section>

        <section class="bg-gray-900 border border-gray-800 rounded-2xl shadow-xl overflow-hidden">
            <div class="p-5 border-b border-gray-800 flex justify-between items-center bg-gray-900/50">
                <h2 class="text-lg font-bold text-indigo-400 flex items-center gap-2">🚀 港股智慧矩陣選股潛力清單</h2>
                <span id="match-count" class="bg-indigo-950 text-indigo-300 text-xs font-semibold px-2.5 py-0.5 rounded border border-indigo-800">載入中...</span>
            </div>
            
            <div class="overflow-x-auto">
                <table class="min-w-full text-left text-sm text-gray-300">
                    <thead>
                        <tr class="border-b border-gray-700 text-gray-400 font-medium bg-gray-900/40">
                            <th class="p-4 w-12 text-center">🌟</th>
                            <th class="p-4">股票代號 / 名稱</th>
                            <th class="p-4">所屬板塊</th>
                            <th class="p-4 text-right">最新現價</th>
                            <th class="p-4 text-center">智慧標籤</th>
                            <th class="p-4 text-right font-bold text-indigo-400 pr-6">綜合潛力得分</th>
                        </tr>
                    </thead>
                    <tbody id="stock-table-body">
                        <tr><td colspan="6" class="p-8 text-center text-gray-500">正在分析資料庫數據，請稍候...</td></tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>

    <script type="module">
        import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm'

        // 你的 Supabase 連線資訊
        const SUPABASE_URL = 'https://dfeqgzgjnkcinduhaqbx.supabase.co'; 
        const SUPABASE_ANON_KEY = 'sb_publishable_eOJwtn52IK-ud7RAvZlXKQ_8Io078XT'; 
        const TABLE_NAME = 'money_flow_hk'; 

        const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

        let latestMarketData = [];
        let watchlist = JSON.parse(localStorage.getItem('hk_dashboard_watchlist')) || [];

        // 獲取 UI 元件
        const wFlowSlider = document.getElementById('w-flow');
        const wTechSlider = document.getElementById('w-tech');
        const wVolSlider = document.getElementById('w-vol');
        const filterVolSlider = document.getElementById('filter-vol');

        const wFlowVal = document.getElementById('w-flow-val');
        const wTechVal = document.getElementById('w-tech-val');
        const wVolVal = document.getElementById('w-vol-val');
        const filterVolVal = document.getElementById('filter-vol-val');

        // AASTOCKS 連結產生器
        function generateAastocksUrl(ticker) {
            let cleanId = String(ticker).replace('.HK', '').trim();
            if (cleanId.length <= 4 && !isNaN(cleanId)) {
                cleanId = cleanId.padStart(6, '0');
            }
            return `https://charts.aastocks.com/servlet/Charts?stockid=${cleanId}.HK&period=6&type=1`;
        }

        // 金額格式化
        function formatMoney(value) {
            if (value == null) return '-';
            const num = Number(value);
            const absNum = Math.abs(num);
            if (absNum >= 1000000) return (num / 1000000).toFixed(1) + ' M';
            if (absNum >= 10000) return (num / 10000).toFixed(1) + ' 萬';
            return num.toFixed(1);
        }

        // 核心：從 Supabase 讀取最新數據
        async function fetchSupabaseData() {
            try {
                // 1. 抓取最新的 Record_Date
                const { data: dateData, error: dateError } = await supabase
                    .from(TABLE_NAME)
                    .select('Record_Date')
                    .order('Record_Date', { ascending: false })
                    .limit(1);

                if (dateError) throw dateError;
                if (!dateData || dateData.length === 0) {
                    document.getElementById('stock-table-body').innerHTML = `<tr><td colspan="6" class="p-8 text-center text-red-400">資料庫內無數據</td></tr>`;
                    return;
                }

                const latestDate = dateData[0].Record_Date;
                document.getElementById('latest-date').textContent = latestDate;

                // 2. 根據最新日期抓取該天所有股票
                const { data, error } = await supabase
                    .from(TABLE_NAME)
                    .select('*')
                    .eq('Record_Date', latestDate)
                    .limit(2000);

                if (error) throw error;

                latestMarketData = data;

                // 3. 首次觸發計算與渲染
                calculateAndRender();

            } catch (err) {
                console.error("連線 Supabase 失敗:", err);
                document.getElementById('stock-table-body').innerHTML = `<tr><td colspan="6" class="p-8 text-center text-red-400">讀取 Supabase 出錯: ${err.message}</td></tr>`;
            }
        }

        // 核心：權重矩陣實時運算
        function calculateAndRender() {
            if (latestMarketData.length === 0) return;

            const wFlow = parseInt(wFlowSlider.value);
            const wTech = parseInt(wTechSlider.value);
            const wVol = parseInt(wVolSlider.value);
            const minVolspike = parseInt(filterVolSlider.value) / 10; 

            wFlowVal.textContent = wFlow + '%';
            wTechVal.textContent = wTech + '%';
            wVolVal.textContent = wVol + '%';
            filterVolVal.textContent = minVolspike.toFixed(1) + 'x';

            const totalWeight = wFlow + wTech + wVol;

            // 1. 動態將你的 Python 上傳數據進行 0-100 的相對分數歸一化 (Normalization)
            // 找出全場最大值以便對應滑桿評分
            const maxFlow5D = Math.max(...latestMarketData.map(r => Math.abs(Number(r['5D_flow']) || 0)), 1);
            const maxVolspike = Math.max(...latestMarketData.map(r => Number(r.Volspike) || 0), 1);

            let processed = latestMarketData.map(r => {
                // 將 5D_flow 轉為分數 (流入越高分數越高)
                const flowFlow = Number(r['5D_flow']) || 0;
                let flowScore = flowFlow > 0 ? (flowFlow / maxFlow5D) * 100 : 0;

                // 技術面分數 (結合 MACD 大於 0 與 RSI 的合理區間)
                let techScore = 50;
                if (Number(r.MACD) > 0) techScore += 25;
                if (Number(r.RSI) >= 40 && Number(r.RSI) <= 65) techScore += 25; // 處於安全多頭區

                // 量能分數 (Volspike 越高分數越高)
                const spikeVal = Number(r.Volspike) || 0;
                let volScore = (spikeVal / maxVolspike) * 100;

                // 計算綜合得分
                let finalScore = 0;
                if (totalWeight > 0) {
                    finalScore = ((flowScore * wFlow) + (techScore * wTech) + (volScore * wVol)) / totalWeight;
                }

                return {
                    ticker: r.ticker,
                    name: r.company_name || '未知公司',
                    sector: r.sector || '其他板塊',
                    price: Number(r.price) || 0,
                    Volspike: spikeVal,
                    accel: r.accel,
                    flow_5d: flowFlow,
                    finalScore: finalScore
                };
            });

            // 2. 執行最右側滑桿的 Volspike 最小過濾
            processed = processed.filter(stock => stock.Volspike >= minVolspike);

            // 3. 排序
            processed.sort((a, b) => b.finalScore - a.finalScore);

            // 4. 渲染
            renderTable(processed);
            renderSectorClusters(processed);
            document.getElementById('match-count').textContent = `${processed.length} 隻符合篩選`;
        }

        // 渲染表格
        function renderTable(stocks) {
            const tbody = document.getElementById('stock-table-body');
            tbody.innerHTML = '';

            if (stocks.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" class="p-8 text-center text-gray-500">無符合當前 Volspike 篩選標準的股票</td></tr>`;
                return;
            }

            stocks.forEach(stock => {
                const isStarred = watchlist.includes(stock.ticker);
                const tr = document.createElement('tr');
                tr.className = 'border-b border-gray-800/60 hover:bg-gray-800/20 transition-colors';

                let badgeHtml = '';
                if (stock.Volspike >= 1.5) {
                    badgeHtml += `<span class="bg-red-950 text-red-400 border border-red-900 text-[10px] px-2 py-0.5 rounded-md font-bold">🔥 ${stock.Volspike.toFixed(1)}x 爆量</span> `;
                }
                if (stock.accel === 'Y' || stock.accel === 'Yes') {
                    badgeHtml += `<span class="bg-indigo-950 text-indigo-400 border border-indigo-900 text-[10px] px-2 py-0.5 rounded-md font-bold">⚡ 加速</span>`;
                }
                if (!badgeHtml) badgeHtml = `<span class="text-gray-600 text-xs">-</span>`;

                tr.innerHTML = `
                    <td class="p-4 text-center cursor-pointer text-base select-none text-yellow-500" data-ticker="${stock.ticker}">
                        ${isStarred ? '⭐' : '☆'}
                    </td>
                    <td class="p-4 font-mono font-bold">
                        <a href="${generateAastocksUrl(stock.ticker)}" target="_blank" class="text-blue-400 hover:underline">🔗 ${stock.ticker}</a>
                        <br><span class="text-xs text-gray-500 font-sans font-normal">${stock.name}</span>
                    </td>
                    <td class="p-4 text-gray-400 font-medium">${stock.sector}</td>
                    <td class="p-4 text-right font-mono text-yellow-500 font-bold">${stock.price.toFixed(2)}</td>
                    <td class="p-4 text-center">${badgeHtml}</td>
                    <td class="p-4 text-right font-mono text-emerald-400 font-extrabold text-base pr-6">${stock.finalScore.toFixed(1)}</td>
                `;

                // 綁定星星點擊
                tr.querySelector('td').addEventListener('click', function(e) {
                    e.stopPropagation();
                    toggleStar(this.getAttribute('data-ticker'));
                });

                tbody.appendChild(tr);
            });
        }

        // 渲染「板塊共振牆」
        function renderSectorClusters(stocks) {
            const container = document.getElementById('sector-grid');
            container.innerHTML = '';

            // 實時動態收集全場所有出現過的板塊名稱
            const sectorGroups = {};
            stocks.forEach(stock => {
                if (!sectorGroups[stock.sector]) sectorGroups[stock.sector] = [];
                sectorGroups[stock.sector].push(stock);
            });

            // 將板塊按照內部股票數量由多到少排序 (把熱門板塊排前面)
            const sortedSectors = Object.keys(sectorGroups).sort((a, b) => sectorGroups[b].length - sectorGroups[a].length);

            sortedSectors.forEach(sectorName => {
                const groupStocks = sectorGroups[sectorName];
                // 每一個板塊只展示前 8 隻得分最高的股票方塊，避免畫面太擁擠
                const displayStocks = groupStocks.slice(0, 8);

                const card = document.createElement('div');
                card.className = 'bg-gray-950 p-4 rounded-xl border border-gray-800 space-y-3';

                let badgeStyle = 'bg-gray-900 text-gray-500';
                if (groupStocks.length >= 4) badgeStyle = 'bg-red-950 text-red-400 border border-red-900 animate-pulse font-bold';
                else if (groupStocks.length > 0) badgeStyle = 'bg-indigo-950 text-indigo-400';

                card.innerHTML = `
                    <div class="flex justify-between items-center border-b border-gray-800 pb-1.5">
                        <span class="font-bold text-xs text-gray-400 truncate max-w-[150px]" title="${sectorName}">${sectorName}</span>
                        <span class="text-[10px] px-2 py-0.5 rounded-md shrink-0 ${badgeStyle}">${groupStocks.length} 隻符合</span>
                    </div>
                    <div class="flex flex-wrap gap-2 pt-1 min-h-[40px]"></div>
                `;

                const flexBox = card.querySelector('div:last-child');
                displayStocks.forEach(stock => {
                    const block = document.createElement('span');
                    
                    // 方塊大小對應 5日資金大小
                    let sizeClass = 'text-xs px-2 py-1';
                    if (Math.abs(stock.flow_5d) > 2000000) sizeClass = 'text-sm px-2.5 py-1 font-bold border border-emerald-500/20';
                    
                    // 顏色深淺對應即時計算出來的綜合權重得分
                    let bgOpacity = 'bg-emerald-950/30 text-emerald-500';
                    if (stock.finalScore >= 75) bgOpacity = 'bg-emerald-500 text-gray-950 font-black shadow-lg';
                    else if (stock.finalScore >= 55) bgOpacity = 'bg-emerald-600/70 text-white font-bold';
                    else if (stock.finalScore >= 35) bgOpacity = 'bg-emerald-800/40 text-emerald-300';

                    block.className = `rounded-lg font-mono cursor-pointer transition-all hover:scale-105 select-none truncate max-w-[90px] ${sizeClass} ${bgOpacity}`;
                    block.innerHTML = stock.ticker.replace('.HK', '');
                    block.title = `${stock.name}\n智慧得分: ${stock.finalScore.toFixed(1)}\n5日資金流: ${formatMoney(stock.flow_5d)}\nVolspike: ${stock.Volspike.toFixed(1)}x`;
                    
                    block.onclick = () => toggleStar(stock.ticker);
                    flexBox.appendChild(block);
                });

                container.appendChild(card);
            });

            if (sortedSectors.length === 0) {
                container.innerHTML = `<div class="col-span-full text-center text-gray-600 py-4 text-xs">無符合條件的板塊數據</div>`;
            }
        }

        // 自選觀察名單切換
        function toggleStar(ticker) {
            if (watchlist.includes(ticker)) {
                watchlist = watchlist.filter(t => t !== ticker);
            } else {
                watchlist.push(ticker);
            }
            localStorage.setItem('hk_dashboard_watchlist', JSON.stringify(watchlist));
            calculateAndRender();
        }

        // 綁定滑桿即時連動
        [wFlowSlider, wTechSlider, wVolSlider, filterVolSlider].forEach(slider => {
            slider.addEventListener('input', calculateAndRender);
        });

        // 進入網頁自動加載
        document.addEventListener('DOMContentLoaded', fetchSupabaseData);
    </script>
</body>
</html>
